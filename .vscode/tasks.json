{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "sensorRunArgs",
      "type": "promptString",
      "description": "Arguments for aegis_sensor_win32",
      "default": "--duration-seconds 1"
    }
  ],
  "tasks": [
    {
      "label": "sensor: configure debug",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "configure",
        "-Preset",
        "msvc-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "sensor: configure debug fresh",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "configure",
        "-Preset",
        "msvc-debug",
        "-Fresh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "sensor: build debug",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "build",
        "-Preset",
        "msvc-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "sensor: test debug",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "test",
        "-Preset",
        "msvc-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "sensor: run debug",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "run",
        "-Preset",
        "msvc-debug",
        "-RunArgs",
        "${input:sensorRunArgs}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "sensor: all debug fresh",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "all",
        "-Preset",
        "msvc-debug",
        "-Fresh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "sensor: configure release",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "configure",
        "-Preset",
        "msvc-release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "sensor: configure release fresh",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "configure",
        "-Preset",
        "msvc-release",
        "-Fresh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "sensor: build release",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "build",
        "-Preset",
        "msvc-release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "sensor: test release",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "test",
        "-Preset",
        "msvc-release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "sensor: run release",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "run",
        "-Preset",
        "msvc-release",
        "-RunArgs",
        "${input:sensorRunArgs}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "sensor: all release fresh",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\sensor\\tools\\invoke-msvc-cmake.ps1",
        "-Action",
        "all",
        "-Preset",
        "msvc-release",
        "-Fresh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
