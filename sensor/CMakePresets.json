{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 0,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "msvc-base",
      "hidden": true,
      "generator": "Ninja",
      "architecture": {
        "strategy": "external",
        "value": "x64"
      },
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": true,
        "CMAKE_CXX_EXTENSIONS": false,
        "CMAKE_EXPORT_COMPILE_COMMANDS": true
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "msvc-debug",
      "inherits": [
        "msvc-base"
      ],
      "displayName": "MSVC Debug",
      "description": "Debug build using MSVC from an initialized Developer shell.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "msvc-release",
      "inherits": [
        "msvc-base"
      ],
      "displayName": "MSVC Release",
      "description": "Release build using MSVC from an initialized Developer shell.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "msvc-debug",
      "displayName": "Build MSVC Debug",
      "configurePreset": "msvc-debug"
    },
    {
      "name": "msvc-release",
      "displayName": "Build MSVC Release",
      "configurePreset": "msvc-release"
    }
  ],
  "testPresets": [
    {
      "name": "msvc-debug",
      "displayName": "Test MSVC Debug",
      "configurePreset": "msvc-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "msvc-release",
      "displayName": "Test MSVC Release",
      "configurePreset": "msvc-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}